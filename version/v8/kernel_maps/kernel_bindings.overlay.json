    "layernorm_forward": {
      "note": "Generic LayerNorm binding with explicit gamma and beta.",
      "params": [
        {
          "name": "input",
          "source": "activation:input",
          "cast": "const float*"
        },
        {
          "name": "gamma",
          "source": "weight_f:gamma",
          "alt": ["ln1_gamma", "ln2_gamma", "final_ln_weight", "branch_norm_gamma"]
        },
        {
          "name": "beta",
          "source": "weight_f:beta",
          "alt": ["ln1_beta", "ln2_beta", "final_ln_bias", "branch_norm_beta"]
        },
        {
          "name": "output",
          "source": "output:output",
          "cast": "float*"
        },
        {
          "name": "mean_cache_slice",
          "source": "null"
        },
        {
          "name": "rstd_cache_slice",
          "source": "null"
        },
        {
          "name": "num_tokens_in_slice",
          "source": "dim:seq_len"
        },
        {
          "name": "d_model",
          "source": "dim:embed_dim"
        },
        {
          "name": "eps",
          "source": "dim:rms_eps"
        }
      ]
    },
