{
  "version": 1,
  "description": "v7 gradient rules for IR2 backward synthesis. 'ready' rules can lower today; 'todo' rules fail-fast unless partial mode is enabled.",
  "rules": {
    "dense_embedding_lookup_backward": {
      "status": "ready",
      "requires_saved": [
        "token_ids",
        "weight"
      ],
      "extra_saved": [],
      "backward_ops": [
        {
          "role": "core",
          "kernel_id": "embedding_backward_f32",
          "reads": [
            "saved:token_ids",
            "grad:out"
          ],
          "writes": [
            {
              "name": "d_token_embeddings",
              "kind": "tmp_grad_weight",
              "target_weight": "weight"
            },
            {
              "name": "d_pos_embeddings",
              "kind": "aux",
              "tensor": "aux.d_pos_embeddings"
            }
          ]
        }
      ]
    },
    "rmsnorm_backward": {
      "status": "ready",
      "requires_saved": [
        "input",
        "gamma",
        "rstd_cache"
      ],
      "extra_saved": [],
      "backward_ops": [
        {
          "role": "core",
          "kernel_id": "rmsnorm_backward",
          "reads": [
            "grad:output",
            "saved:input",
            "saved_weight:gamma",
            "saved:rstd_cache"
          ],
          "writes": [
            {
              "name": "d_input",
              "kind": "grad_activation",
              "target_input": "input"
            },
            {
              "name": "d_gamma",
              "kind": "tmp_grad_weight",
              "target_weight": "gamma"
            }
          ]
        }
      ]
    },
    "matmul_backward": {
      "status": "ready",
      "requires_saved": [
        "input",
        "W"
