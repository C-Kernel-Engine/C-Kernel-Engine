    "preferred": {"prefill": "head", "decode": "head"},
    "strategies": [
      {
        "name": "head",
        "partition_dim": "H",
        "param_style": "ith_nth",
        "notes": "Parallelize across heads; each thread handles one or more heads."
      }
    ]
  },
  "constraints": {
    "alignment": {"AE": 64, "AD": 64},
    "notes": "Q5_0 requires K dimension multiple of 256 for dequantization. Produces head-major output for efficient attention."
  },
  "fuses": [
    "rmsnorm_forward",
    "gemv_q5_0_q8_0",
    "gemv_q5_0_q8_0",
    "gemv_q8_0_q8_0"
  ],
  "impl": {
    "function": "fused_rmsnorm_qkv_prefill_head_major_quant",
    "sources": ["src/kernels/fused/rmsnorm_qkv.c"],
    "variants": [
