+#ifndef LLAMA_DEBUG_V66_H
+#define LLAMA_DEBUG_V66_H
+
+/*
+ * llama-debug.h - Debug hooks for v6.6 layer-by-layer comparison
+ *
+ * Usage:
+ *   1. Apply this patch to llama.cpp
+ *   2. Build with: make LLAMA_V66_DEBUG=1
+ *   3. Run: LLAMA_DEBUG_FILE=debug.json ./main -m model.gguf -p "test" -n 1
+ *   4. Compare debug.json against v6.6 output
+ */
+
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+
+#ifdef LLAMA_V66_DEBUG
+
+static FILE* g_debug_file = NULL;
+static int g_debug_first = 1;
+
+static inline void llama_debug_init(void) {
+    const char* path = getenv("LLAMA_DEBUG_FILE");
+    if (!path) path = "llama_debug.json";
+    g_debug_file = fopen(path, "w");
+    if (g_debug_file) {
+        fprintf(g_debug_file, "{\n");
+        g_debug_first = 1;
+    }
+}
+
+static inline void llama_debug_close(void) {
+    if (g_debug_file) {
+        fprintf(g_debug_file, "\n}\n");
+        fclose(g_debug_file);
+        g_debug_file = NULL;
+    }
+}
+
+static inline void llama_debug_tensor(const char* name, const float* data, int size) {
+    if (!g_debug_file) return;
+
+    if (!g_debug_first) fprintf(g_debug_file, ",\n");
+    g_debug_first = 0;
+
+    fprintf(g_debug_file, "  \"%s\": {\n", name);
+    fprintf(g_debug_file, "    \"size\": %d,\n", size);
+
+    // Stats
+    float min_val = data[0], max_val = data[0], sum = 0;
+    for (int i = 0; i < size; i++) {
+        if (data[i] < min_val) min_val = data[i];
+        if (data[i] > max_val) max_val = data[i];
+        sum += data[i];
+    }
+    fprintf(g_debug_file, "    \"min\": %.8f,\n", min_val);
+    fprintf(g_debug_file, "    \"max\": %.8f,\n", max_val);
+    fprintf(g_debug_file, "    \"mean\": %.8f,\n", sum / size);
+
+    // First N values for comparison
+    int n = (size < 32) ? size : 32;
+    fprintf(g_debug_file, "    \"first_%d\": [", n);
+    for (int i = 0; i < n; i++) {
+        fprintf(g_debug_file, "%.8f%s", data[i], (i < n-1) ? ", " : "");
+    }
+    fprintf(g_debug_file, "],\n");
+
+    // Last N values
+    fprintf(g_debug_file, "    \"last_%d\": [", n);
+    int start = (size > n) ? size - n : 0;
+    for (int i = start; i < size; i++) {
+        fprintf(g_debug_file, "%.8f%s", data[i], (i < size-1) ? ", " : "");
+    }
+    fprintf(g_debug_file, "]\n");
+    fprintf(g_debug_file, "  }");
+
+    fflush(g_debug_file);
+}
+
+#define LLAMA_DEBUG_INIT() llama_debug_init()
+#define LLAMA_DEBUG_CLOSE() llama_debug_close()
+#define LLAMA_DEBUG_TENSOR(name, data, size) llama_debug_tensor(name, data, size)
+
+#else
+
+#define LLAMA_DEBUG_INIT()
+#define LLAMA_DEBUG_CLOSE()
+#define LLAMA_DEBUG_TENSOR(name, data, size)
+
+#endif // LLAMA_V66_DEBUG
+
+#endif // LLAMA_DEBUG_V66_H
