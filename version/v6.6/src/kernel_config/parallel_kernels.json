        "requires": ["avx"],
        "speedup": "2.4-3.1x"
      },
      "parallel_ref": {
        "function": "gemv_q4_k_q8_k_parallel",
        "params": ["y", "W", "x_q8", "M", "K", "ith", "nth"],
        "requires": [],
        "speedup": "1.5-2x"
      },
      "simd": {
        "function": "gemv_q4_k_q8_k",
        "params": ["y", "W", "x_q8", "M", "K"],
        "requires": ["avx"]
      },
      "ref": {
        "function": "gemv_q4_k_q8_k_ref",
        "params": ["y", "W", "x_q8", "M", "K"],
        "requires": []
      }
    },

    "gemv_q6_k_q8_k": {
