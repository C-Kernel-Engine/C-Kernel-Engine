      "good": 0.9,
      "warn": 0.6,
      "format": "pct",
      "higher_is_better": true
    },
    {
      "key": "prefix_integrity",
      "label": "Prefix",
      "source": "prefix_integrity",
      "probe_type": "all",
      "good": 0.9,
      "warn": 0.7,
      "format": "pct",
      "higher_is_better": true,
      "headline": true
    },
    {
      "key": "adherence",
      "label": "Adherence",
      "source": "adherence",
      "probe_type": "svg_gen",
