  "competencies": [
    {
      "id": "bundle_closure",
      "description": "Emit exactly one clean [bundle] and stop at [/bundle].",
      "must_appear_in_stages": ["stage_a", "stage_b"]
    },
    {
      "id": "prompt_output_separation",
      "description": "Keep topic, goal, audience, and control markers out of the output bundle.",
      "must_appear_in_stages": ["stage_a", "stage_b"]
    },
    {
      "id": "family_routing",
      "description": "Choose the correct family from bounded intent without explicit layout tags.",
      "must_appear_in_stages": ["stage_a", "stage_b"]
    },
    {
      "id": "form_selection",
      "description": "Choose the correct sibling form within the selected family.",
      "must_appear_in_stages": ["stage_a", "stage_b"]
    },
    {
      "id": "style_inference",
      "description": "Infer theme, tone, density, and background from topic, goal, audience, and hints.",
      "must_appear_in_stages": ["stage_a", "stage_b"]
    },
    {
      "id": "topology_budgeting",
      "description": "Infer the correct count bundle and density under weaker prompt control.",
      "must_appear_in_stages": ["stage_a", "stage_b"]
    },
    {
      "id": "paraphrase_robustness",
      "description": "Preserve bundle choice under wording shifts and field-order changes.",
      "must_appear_in_stages": ["stage_b"]
    },
    {
      "id": "recombination",
      "description": "Generalize to seen topic x seen goal combinations that were not paired in train.",
      "must_appear_in_stages": ["stage_b"]
    },
    {
      "id": "family_balance",
      "description": "Avoid improving one family by collapsing another.",
      "must_appear_in_stages": ["stage_a", "stage_b"]
    }
  ],
  "surfaces": [
    {
      "id": "explicit_bundle_anchor",
      "surface_type": "anchor",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["bundle_closure", "prompt_output_separation"],
      "frontiers": ["topic_leakage_into_output", "stop_leakage"],
      "notes": "Frozen spec16 explicit bundle prompts carried forward unchanged."
    },
    {
      "id": "clean_stop_anchor",
      "surface_type": "hygiene",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["bundle_closure", "prompt_output_separation"],
      "frontiers": ["stop_leakage", "prompt_copy_leakage"],
      "notes": "Positive clean-stop examples only; no warning-language rows about wrappers or control tokens."
    },
    {
      "id": "explicit_permuted_anchor",
      "surface_type": "anchor",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["bundle_closure", "prompt_output_separation"],
      "frontiers": ["anchor_retention_failure", "stop_leakage"],
      "notes": "Carry the full explicit bundle prompt forward, but vary tag order so bundle closure does not depend on one fixed prompt layout."
    },
    {
      "id": "layout_topic_bridge",
      "surface_type": "bridge",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["family_routing", "bundle_closure"],
      "frontiers": ["bridge_abruptness", "default_family_attractor"],
      "notes": "Internal scaffold surface only: keep layout explicit while introducing topic, goal, and audience."
    },
    {
      "id": "layout_form_bridge",
      "surface_type": "bridge",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["form_selection", "family_routing"],
      "frontiers": ["bridge_abruptness", "default_form_attractor"],
      "notes": "Internal scaffold surface only: keep layout and form explicit while style and topology still need to be inferred."
    },
    {
      "id": "layout_hint_bridge",
      "surface_type": "bridge",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["style_inference", "topology_budgeting"],
      "frontiers": ["bridge_abruptness", "default_style_attractor", "topology_count_drift"],
      "notes": "Internal scaffold surface only: keep family and form explicit, but infer the remaining style and count bundle from bounded hints."
    },
    {
      "id": "intent_family_bridge",
      "surface_type": "intent",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["family_routing", "form_selection"],
      "frontiers": ["default_family_attractor", "default_form_attractor"],
      "notes": "Primary [topic][goal][audience] prompts with no layout/style fields."
    },
    {
      "id": "form_disambiguation_contrast",
      "surface_type": "contrast",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["form_selection"],
      "frontiers": ["default_form_attractor", "goal_family_confusion"],
      "notes": "Near-neighbor prompts that differ by the sibling form they should trigger."
    },
    {
      "id": "style_bundle_inference",
      "surface_type": "intent",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["style_inference"],
      "frontiers": ["default_style_attractor", "audience_style_entanglement"],
      "notes": "Audience, emphasis, and content_pack control the canonical theme/tone/density/background bundle."
    },
    {
      "id": "topology_budget_bridge",
      "surface_type": "intent",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["topology_budgeting"],
      "frontiers": ["topology_count_drift"],
      "notes": "Constraint and content_pack variations teach count and density changes without changing family."
    },
    {
      "id": "topic_goal_recombination",
      "surface_type": "bridge",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["recombination", "family_routing", "style_inference"],
      "frontiers": ["topic_goal_recombination_failure", "default_family_attractor"],
      "notes": "Seen topics and seen goals appear in unseen pairings."
    },
    {
      "id": "paraphrase_bridge",
      "surface_type": "bridge",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["paraphrase_robustness"],
      "frontiers": ["paraphrase_brittleness"],
      "notes": "Prompt wording shifts and field-order changes preserve the same target bundle."
    },
    {
      "id": "family_confusion_contrast",
      "surface_type": "contrast",
      "families": ["memory_map", "timeline", "system_diagram"],
      "competencies": ["family_routing", "family_balance"],
      "frontiers": ["goal_family_confusion", "hidden_family_imbalance"],
      "notes": "Near-neighbor intents that should choose different families."
    }
  ],
  "predicted_failure_frontiers": [
    {
      "id": "anchor_retention_failure",
      "severity": "high",
      "description": "Even explicit anchor prompts stop producing the frozen bundle contract reliably once the branch curriculum weakens prompt control.",
      "covered_by_surfaces": ["explicit_bundle_anchor", "explicit_permuted_anchor", "clean_stop_anchor"]
    },
    {
      "id": "bridge_abruptness",
      "severity": "high",
      "description": "The jump from explicit control to pure bounded intent is too steep, so the model loses family or form before the bridge is learned.",
      "covered_by_surfaces": ["layout_topic_bridge", "layout_form_bridge", "layout_hint_bridge"]
    },
    {
      "id": "default_family_attractor",
      "severity": "high",
      "description": "The model routes most prompts to one familiar family regardless of intent.",
      "covered_by_surfaces": ["layout_topic_bridge", "intent_family_bridge", "topic_goal_recombination", "family_confusion_contrast"]
    },
    {
      "id": "default_form_attractor",
      "severity": "high",
      "description": "The model chooses the dominant sibling form inside a family instead of the correct one.",
      "covered_by_surfaces": ["layout_form_bridge", "intent_family_bridge", "form_disambiguation_contrast"]
    },
    {
      "id": "default_style_attractor",
      "severity": "high",
      "description": "Theme, tone, density, or background collapse to the training-dominant bundle.",
      "covered_by_surfaces": ["style_bundle_inference"]
    },
    {
      "id": "audience_style_entanglement",
      "severity": "medium",
      "description": "Audience or emphasis hints leak into the wrong style bundle or override the wrong axis.",
      "covered_by_surfaces": ["style_bundle_inference", "topic_goal_recombination"]
    },
    {
      "id": "topology_count_drift",
      "severity": "high",
      "description": "Counts default to seen values instead of the intended compact/balanced/dense bundle.",
      "covered_by_surfaces": ["topology_budget_bridge"]
    },
    {
      "id": "topic_leakage_into_output",
      "severity": "high",
      "description": "Topic ids, goals, or prompt fields appear inside the emitted bundle.",
      "covered_by_surfaces": ["explicit_bundle_anchor", "clean_stop_anchor"]
    },
    {
      "id": "prompt_copy_leakage",
      "severity": "high",
      "description": "The model copies [task:svg], [OUT], or similar control markers into the decode path.",
      "covered_by_surfaces": ["clean_stop_anchor"]
    },
    {
      "id": "stop_leakage",
      "severity": "high",
      "description": "The model keeps generating after the first valid [/bundle].",
      "covered_by_surfaces": ["explicit_bundle_anchor", "clean_stop_anchor"]
    },
    {
      "id": "paraphrase_brittleness",
      "severity": "medium",
      "description": "Small wording shifts change the chosen bundle even though the intent is the same.",
      "covered_by_surfaces": ["paraphrase_bridge"]
    },
    {
      "id": "topic_goal_recombination_failure",
      "severity": "medium",
      "description": "Seen topics and goals fail when paired in unseen combinations.",
      "covered_by_surfaces": ["topic_goal_recombination"]
    },
    {
      "id": "goal_family_confusion",
      "severity": "medium",
      "description": "Near-neighbor goals that should choose different families or forms collapse together.",
      "covered_by_surfaces": ["form_disambiguation_contrast", "family_confusion_contrast"]
    },
    {
      "id": "hidden_family_imbalance",
      "severity": "high",
      "description": "Visible improvements hide a collapse in one family on hidden probes.",
      "covered_by_surfaces": ["family_confusion_contrast", "topic_goal_recombination"]
    }
  ],
  "curriculum_stages": [
    {
      "id": "stage_a",
      "purpose": "Preserve spec16 bundle closure while teaching the first bounded intent bridge.",
      "surface_mix": [
        {"surface": "explicit_bundle_anchor", "weight": 24},
        {"surface": "explicit_permuted_anchor", "weight": 10},
        {"surface": "clean_stop_anchor", "weight": 8},
        {"surface": "layout_topic_bridge", "weight": 16},
        {"surface": "layout_form_bridge", "weight": 14},
        {"surface": "layout_hint_bridge", "weight": 10},
        {"surface": "intent_family_bridge", "weight": 8},
        {"surface": "form_disambiguation_contrast", "weight": 4},
        {"surface": "style_bundle_inference", "weight": 3},
        {"surface": "topology_budget_bridge", "weight": 2},
        {"surface": "family_confusion_contrast", "weight": 1}
      ],
      "notes": "No raw repair-prose rows. Every surface must remain compiler-valid and bundle-canonical. Stage A now includes explicit scaffold bridges so the prompt-control drop is gradual instead of abrupt."
    },
    {
      "id": "stage_b",
      "purpose": "Shift the burden from explicit control to intent planning without losing closure or family balance.",
      "surface_mix": [
        {"surface": "explicit_bundle_anchor", "weight": 16},
        {"surface": "explicit_permuted_anchor", "weight": 8},
        {"surface": "clean_stop_anchor", "weight": 6},
        {"surface": "layout_topic_bridge", "weight": 12},
        {"surface": "layout_form_bridge", "weight": 10},
        {"surface": "layout_hint_bridge", "weight": 10},
        {"surface": "intent_family_bridge", "weight": 12},
        {"surface": "topic_goal_recombination", "weight": 8},
        {"surface": "form_disambiguation_contrast", "weight": 6},
        {"surface": "style_bundle_inference", "weight": 5},
        {"surface": "topology_budget_bridge", "weight": 3},
        {"surface": "paraphrase_bridge", "weight": 2},
        {"surface": "family_confusion_contrast", "weight": 2}
      ],
      "notes": "Keep explicit anchors and scaffold bridges alive, but make intent prompts and recombination the main planning pressure once anchor retention is stable."
    }
  ],
  "holdouts": {
    "visible": {
      "per_family": 12,
      "required_surfaces": [
        "intent_family_bridge",
        "form_disambiguation_contrast",
        "style_bundle_inference",
        "topology_budget_bridge"
      ],
      "balance_rule": "Each family must appear equally across visible prompt surfaces."
    },
    "hidden": {
      "per_family": 6,
      "required_surfaces": [
        "topic_goal_recombination",
        "paraphrase_bridge",
        "family_confusion_contrast"
      ],
      "balance_rule": "Each family must appear equally across hidden paraphrase and recombination probes."
    },
    "non_regression": ["explicit_bundle_anchor"]
  },
  "promotion_gates": [
    "Compiler and canonicalizer parity must pass before any model training starts.",
    "The curriculum audit must pass with no uncovered failure frontier and no missing form coverage.",
    "Raw exactness must be reported separately from repaired exactness.",
    "No family may regress on hidden probes while another improves.",
    "If remaining errors are mostly deterministic near-misses, continue decode/repair instead of reopening raw repair rungs."
  ],
  "banned_patterns": [
    "Do not add warning-language rows about [OUT], wrappers, singleton tags, or stop markers as the main repair strategy.",
    "Do not mix raw SVG, free-written prose, or family-specific lowerer syntax into the spec17 output contract.",
    "Do not remove anchor coverage in order to make the curriculum look more intent-heavy.",
    "Do not treat better loss alone as evidence that bounded intent planning improved.",
    "Do not change tokenizer, family contract, and model size all at once in the first spec17 rung."
  ]
}
