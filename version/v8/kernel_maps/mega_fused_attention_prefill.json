    {"name": "wq", "dtype": "q5_0", "shape": ["H", "AD", "AE"], "desc": "Q projection weights"},
    {"name": "bq", "dtype": "fp32", "shape": ["H", "AD"], "optional": true, "desc": "Q bias (or NULL)"},
    {"name": "wk", "dtype": "q5_0", "shape": ["KV", "AD", "AE"], "desc": "K projection weights"},
    {"name": "bk", "dtype": "fp32", "shape": ["KV", "AD"], "optional": true, "desc": "K bias (or NULL)"},
    {"name": "wv", "dtype": "q8_0", "shape": ["KV", "AD", "AE"], "desc": "V projection weights"},
    {"name": "bv", "dtype": "fp32", "shape": ["KV", "AD"], "optional": true, "desc": "V bias (or NULL)"},
    {"name": "wo", "dtype": "q5_0", "shape": ["H", "AE", "AD"], "desc": "Output projection weights"},
    {"name": "bo", "dtype": "fp32", "shape": ["AE"], "optional": true, "desc": "Output bias (or NULL)"}
  ],
  "activations": [],
  "runtime_buffers": [
    {"name": "kv_cache_k", "dtype": "fp32", "shape": ["KV", "max_T", "AD"], "desc": "K cache [written starting at start_pos]"},
    {"name": "kv_cache_v", "dtype": "fp32", "shape": ["KV", "max_T", "AD"], "desc": "V cache [written starting at start_pos]"},
    {"name": "rope_cos", "dtype": "fp32", "shape": ["max_T", "D", 2], "desc": "RoPE cos [pos, :D/2]"},
    {"name": "rope_sin", "dtype": "fp32", "shape": ["max_T", "D", 2], "desc": "RoPE sin [pos, :D/2]"}
  ],
  "outputs": [
    {"name": "output", "dtype": "fp32", "shape": ["T", "AE"], "desc": "Output [includes residual add]"}
  ],
  "scratch": [
    {"name": "scratch", "dtype": "fp32", "size_bytes": "mega_fused_attention_prefill_scratch_size()", "desc": "Scratch buffer for attention computation"}
  ],
  "dims": ["T", "E", "AE", "H", "KV", "D", "AD", "max_T"],
  "params": [
    {"name": "start_pos", "dtype": "int32", "desc": "Starting position in KV cache"},
    {"name": "tokens", "dtype": "int32", "desc": "Number of tokens to process"},
    {"name": "cache_capacity", "dtype": "int32", "desc": "KV cache capacity (stride)"},
    {"name": "eps", "dtype": "float32", "desc": "RMSNorm epsilon (typically 1e-5)"}
  ],
  "parallelization": {
