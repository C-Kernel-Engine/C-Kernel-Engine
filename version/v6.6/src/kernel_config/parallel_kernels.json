      }
    }
  },

    "gemv_q8_0_q8_0": {
      "parallel_omp": {
        "function": "gemv_q8_0_q8_0_parallel_omp",
        "params": ["y", "W", "x_q8", "M", "K"],
        "requires": [],
        "speedup": "1.8-2.6x",
        "notes": "Same signature as serial — OpenMP handled internally, no wrapper needed"
      },
      "simd": {
        "function": "gemv_q8_0_q8_0",
        "params": ["y", "W", "x_q8", "M", "K"],
        "requires": ["avx"]
      }
    },

    "gemv_q5_0_q8_0": {
      "parallel_omp": {
        "function": "gemv_q5_0_q8_0_parallel_omp",
        "params": ["y", "W", "x_q8", "M", "K"],
        "requires": [],
        "speedup": "1.6-2.6x",
        "notes": "Same signature as serial — OpenMP handled internally, no wrapper needed"
      },
      "simd": {
        "function": "gemv_q5_0_q8_0",
        "params": ["y", "W", "x_q8", "M", "K"],
