{
  "_meta": {
    "description": "Kernel parameter bindings for data-driven codegen",
    "version": "v6.6",
    "format": {
      "binding_types": [
        "weight:<field_name> - Weight from L-><field> or L_HEADER.<field>",
        "weight_f:<field_name> - Weight as float* (for fp32 weights like gamma)",
        "activation:<offset> - Activation buffer at offset",
        "dim:<dim_name> - Dimension constant (embed_dim, num_heads, etc.)",
        "runtime:<expr_name> - Runtime expression (kv_k, kv_v, rope_cos, rope_sin, pos)",
        "dtype:<dtype_name> - CKDataType enum value",
        "dtype_weight:<field_name> - CKDataType from weight dtype",
        "const:<value> - Literal constant",
        "null - NULL pointer"
      ]
    }
  },
  "bindings": {
    "embedding_forward_q8_0": {
      "params": [
        {"name": "token_ids", "source": "activation:tokens", "cast": "int32_t*"},
