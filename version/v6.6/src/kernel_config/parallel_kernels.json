  "selection_priority": ["parallel_omp", "parallel_simd", "parallel_ref", "simd", "ref"],

  "parallelization_modes": {
    "decode": {
      "strategy": "feature_parallel",
      "variant": "parallel_simd",
      "num_threads": 4,
      "wrapper_template": [
        "#pragma omp parallel num_threads(4)",
        "{",
        "    const int ith = omp_get_thread_num();",
        "    const int nth = omp_get_num_threads();",
        "    KERNEL_CALL(y, W, x, M, K, ith, nth);",
        "}"
      ]
    },
    "prefill": {
      "strategy": "token_parallel",
      "variant": "simd",
      "wrapper_template": [
        "#pragma omp parallel for",
        "for (int t = 0; t < num_tokens; t++) {",
        "    KERNEL_CALL(y + t*M, W, x + t*stride, M, K);",
        "}"
      ]
    }
  }
}
