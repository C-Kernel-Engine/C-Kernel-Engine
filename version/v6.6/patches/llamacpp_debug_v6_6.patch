         // After attention:
         // struct ggml_tensor * cur = llm_build_kv(...)

         /*
          * INSERT DEBUG HOOK: After attention output
          */
+#ifdef LLAMA_V66_DEBUG
+        snprintf(name, sizeof(name), "layer_%d_attn_out", il);
+        LLAMA_DEBUG_TENSOR(name, (float*)cur->data, n_embd);
+#endif

         // After output projection + residual:
         // cur = llm_build_lora_mm(...) // wo projection
         // cur = ggml_add(ctx0, cur, inpSA);  // residual

         /*
          * INSERT DEBUG HOOK: After attention residual
          */
+#ifdef LLAMA_V66_DEBUG
+        snprintf(name, sizeof(name), "layer_%d_attn_residual", il);
+        LLAMA_DEBUG_TENSOR(name, (float*)cur->data, n_embd);
+#endif

         // After FFN layer norm:
         // cur = llm_build_norm(...)

         /*
          * INSERT DEBUG HOOK: After FFN layer norm
          */
+#ifdef LLAMA_V66_DEBUG
+        snprintf(name, sizeof(name), "layer_%d_ln2", il);
+        LLAMA_DEBUG_TENSOR(name, (float*)cur->data, n_embd);
+#endif

         // After MLP (gate, up, silu, down):
         // cur = llm_build_ffn(...)

         /*
          * INSERT DEBUG HOOK: After MLP
          */
+#ifdef LLAMA_V66_DEBUG
+        snprintf(name, sizeof(name), "layer_%d_mlp_out", il);
+        LLAMA_DEBUG_TENSOR(name, (float*)cur->data, n_embd);
+#endif

         // After FFN residual:
         // cur = ggml_add(ctx0, cur, inpL);
         // inpL = cur;

         /*
          * INSERT DEBUG HOOK: After FFN residual (layer output)
          */
+#ifdef LLAMA_V66_DEBUG
+        snprintf(name, sizeof(name), "layer_%d_output", il);
+        LLAMA_DEBUG_TENSOR(name, (float*)cur->data, n_embd);
+#endif
     }

     // After final layer norm:
     // cur = llm_build_norm(...)

+#ifdef LLAMA_V66_DEBUG
+    LLAMA_DEBUG_TENSOR("final_ln", (float*)cur->data, n_embd);
+#endif

     // After lm_head (logits):
     // cur = llm_build_lora_mm(...)

+#ifdef LLAMA_V66_DEBUG
+    LLAMA_DEBUG_TENSOR("logits", (float*)cur->data, n_vocab);
+    LLAMA_DEBUG_CLOSE();
+#endif
 }

