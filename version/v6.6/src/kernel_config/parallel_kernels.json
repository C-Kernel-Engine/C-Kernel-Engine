        "speedup": "2.4-3x (estimated)"
      },
      "parallel_ref": {
        "function": "gemv_q6_k_q8_k_parallel",
        "params": ["y", "W", "x_q8", "M", "K", "ith", "nth"],
        "requires": [],
        "speedup": "1.5-2x"
      },
      "simd": {
        "function": "gemv_q6_k_q8_k",
        "params": ["y", "W", "x_q8", "M", "K"],
        "requires": ["avx"]
      }
    },

    "gemv_q5_0": {
      "parallel_simd": {
        "function": "gemv_q5_0_parallel_simd",
        "params": ["y", "W", "x", "M", "K", "ith", "nth"],
        "requires": ["avx"],
        "speedup": "2-3x (estimated)",
        "input_dtype": "fp32"
      },
      "parallel_ref": {
        "function": "gemv_q5_0_parallel",
        "params": ["y", "W", "x", "M", "K", "ith", "nth"],
