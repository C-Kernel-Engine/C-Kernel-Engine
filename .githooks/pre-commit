#!/bin/bash
# =============================================================================
# CK-Engine Pre-Commit Hook
# =============================================================================
# Runs the fast inference-family regression gate for staged runtime/regression
# changes. This keeps the heavy family matrix close to the edit that caused it
# without forcing docs-only commits to wait on model bring-up.
#
# Install: git config core.hooksPath .githooks
# Or:      ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo -e "${YELLOW}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${YELLOW}║           CK-Engine Pre-Commit Validation                  ║${NC}"
echo -e "${YELLOW}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

if [ -n "${CK_SKIP_PRECOMMIT:-}" ]; then
    echo -e "${YELLOW}⚠️  Skipping pre-commit checks (CK_SKIP_PRECOMMIT=1)${NC}"
    exit 0
fi

cd "$ROOT_DIR"

mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACMR)

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
    echo -e "${YELLOW}⚠️  No staged files; skipping pre-commit regression${NC}"
    exit 0
fi

should_run_regression=0
for path in "${STAGED_FILES[@]}"; do
    case "$path" in
        Makefile|.githooks/pre-commit|.githooks/pre-push|.github/workflows/nightly.yml)
            should_run_regression=1
            break
            ;;
        scripts/*|src/*|tests/*)
            should_run_regression=1
            break
            ;;
        version/v7/scripts/*|version/v7/templates/*|version/v7/regression/*|version/v7/src/*|version/v7/README.md)
            should_run_regression=1
            break
            ;;
    esac
done

if [ "$should_run_regression" != "1" ]; then
    echo -e "${GREEN}✓ Staged changes do not affect runtime/regression paths; skipping regression-fast${NC}"
    exit 0
fi

RUN_ROOT="${CK_PRECOMMIT_RUN_ROOT:-/tmp/ck-precommit-regression/runs}"
REPORT_ROOT="${CK_PRECOMMIT_REPORT_ROOT:-/tmp/ck-precommit-regression/reports}"

echo -e "${YELLOW}Running make regression-fast for staged runtime/regression changes...${NC}"
echo -e "${YELLOW}  ↳ run root: ${RUN_ROOT}${NC}"
echo -e "${YELLOW}  ↳ report root: ${REPORT_ROOT}${NC}"

if make regression-fast REGRESSION_ARGS="--run-root ${RUN_ROOT} --report-root ${REPORT_ROOT}" > /tmp/ck_precommit_regression.log 2>&1; then
    echo -e "${GREEN}✓ regression-fast passed${NC}"
    exit 0
fi

echo -e "${RED}✗ regression-fast failed${NC}"
echo "  See /tmp/ck_precommit_regression.log for details"
tail -40 /tmp/ck_precommit_regression.log || true
exit 1
