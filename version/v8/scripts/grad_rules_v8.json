      "extra_saved": [],
      "backward_ops": [
        {
          "role": "core",
          "kernel_id": "gemm_backward_f32",
          "reads": [
            "grad:y",
            "saved:input",
            "saved_weight:W"
          ],
          "writes": [
            {
              "name": "d_input",
              "kind": "grad_activation",
              "target_input": "input"
            },
            {
              "name": "d_weight",
              "kind": "tmp_grad_weight",
              "target_weight": "W"
            },
            {
              "name": "d_bias",
              "kind": "tmp_grad_weight",
              "target_weight": "bias",
              "optional_target_weight": true
            }
          ]
        }
      ]
    },
