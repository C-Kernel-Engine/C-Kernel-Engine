[cell_ref:groups.0.rows.1.0]
[cell_ref:groups.0.rows.1.1]
[cell_ref:groups.0.rows.1.2]
[cell_ref:groups.0.rows.1.3]
[row_state:success]
[/table_row]
[table_row]
[cell_ref:groups.0.rows.2.0]
[cell_ref:groups.0.rows.2.1]
[cell_ref:groups.0.rows.2.2]
[cell_ref:groups.0.rows.2.3]
[row_state:highlight]
[/table_row]
[/table_block]
[table_block]
[block_title_ref:groups.1.title]
[block_caption_ref:groups.1.caption]
[table_header]
[cell_ref:groups.1.header.0]
[cell_ref:groups.1.header.1]
[cell_ref:groups.1.header.2]
[cell_ref:groups.1.header.3]
[/table_header]
[table_row]
[cell_ref:groups.1.rows.0.0]
[cell_ref:groups.1.rows.0.1]
[cell_ref:groups.1.rows.0.2]
[cell_ref:groups.1.rows.0.3]
[row_state:warning]
[/table_row]
[table_row]
[cell_ref:groups.1.rows.1.0]
[cell_ref:groups.1.rows.1.1]
[cell_ref:groups.1.rows.1.2]
[cell_ref:groups.1.rows.1.3]
[row_state:normal]
[/table_row]
[table_row]
[cell_ref:groups.1.rows.2.0]
