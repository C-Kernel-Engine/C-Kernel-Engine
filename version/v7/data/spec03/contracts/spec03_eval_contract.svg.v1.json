{
  "schema": "ck.eval_contract.v1",
  "dataset_type": "svg",
  "goal": "Render valid SVG that follows the closed-vocabulary specialist tag contract.",
  "notes": [
    "spec03 uses tag-prefix prompts only",
    "all probes should stay within the canonical tag vocabulary",
    "extend this contract only when a new tag family has generator and scoring support"
