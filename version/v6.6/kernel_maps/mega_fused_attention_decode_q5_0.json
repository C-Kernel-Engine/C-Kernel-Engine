    "add_inplace_f32",
    "gemv_q5_0_q8_0",
    "add_inplace_f32",
    "gemv_q8_0_q8_0",
    "add_inplace_f32",
    "rope_forward_qk",
    "kv_cache_store",
    "attention_forward_decode_head_major_gqa_flash",
    "gemv_fused_q5_0_bias_dispatch",
    "ck_residual_add_token_major"
  ],
  "parallelization": {
