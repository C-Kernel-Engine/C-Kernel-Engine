          "c",
          "python",
          "sql",
          "```",
          "#include",
          "def ",
          "select "
        ],
        "min_keyword_hits": 2,
        "required_substrings_any_of": [
          "```",
          "#include",
          "def ",
          "select ",
          "SELECT ",
          "int main",
          "import sqlite3"
        ],
        "min_required_substrings_any_of_hits": 1
