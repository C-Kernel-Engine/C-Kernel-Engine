[scene]
[canvas:tall]
[layout:table_matrix]
[theme:infra_dark]
[tone:amber]
[frame:panel]
[density:balanced]
[inset:md]
[gap:sm]
[hero:center]
[columns:1]
[emphasis:top]
[rail:none]
[background:grid]
[connector:line]
[topic:edge_case_matrix]
[header_band]
[kicker_ref:header.kicker]
[headline_ref:header.headline]
[subtitle_ref:header.subtitle]
[/header_band]
[legend_block]
