{
  "version": 2,
  "name": "gemma3",
  "family": "llama",
  "flags": {
    "use_qkv_bias": "from_weights",
    "activation": "geglu",
    "rope": "rope",
    "tokenizer": "sentencepiece",
    "scale_embeddings_sqrt_dim": true,
    "prefer_q8_0_contract": true,
    "prefer_fp32_logits": true,
    "attention": "sliding_window",
    "has_qk_norm": true,
    "post_attention_norm": true,
    "post_ffn_norm": true
  },
  "contract": {
    "tokenizer_contract": {
      "tokenizer_type": "sentencepiece",
      "bos_policy": "model_defined",
      "eos_policy": "model_defined",
      "special_tokens": {
        "source": "manifest_or_gguf"
      }
    },
    "chat_contract": {
      "version": 1,
      "name": "gemma",
      "raw_prompt_allowed": false,
      "turn_prefix": "<start_of_turn>{role}\n",
      "turn_suffix": "<end_of_turn>\n",
      "assistant_generation_prefix": "<start_of_turn>model\n",
      "role_labels": {
        "system": "system",
        "user": "user",
        "assistant": "model"
      },
      "system_prompt_mode": "prepend_first_user",
      "system_prompt_separator": "\n\n",
      "default_system_prompt": "",
      "inject_default_system_prompt": false,
      "force_bos_text_if_tokenizer_add_bos_false": "<bos>",
      "last_user_prefix": "",
      "last_user_prefix_suppression_markers": [],
      "stop_text_markers": ["<end_of_turn>"],
      "token_stop_markers": ["<end_of_turn>"],
      "template_markers": ["<start_of_turn>", "<end_of_turn>"],
      "min_response_tokens": 8
    },
    "attention_contract": {
      "rope_layout": "split",
      "rope_type": "rope",
      "qk_norm": true,
      "kv_layout": "layer_major_kv_cache",
      "attn_variant": "sliding_window",
      "train_runtime_contract": {
        "saved_tensor_kernel_overrides": {
          "attn_weights": "attention_forward_causal_head_major_gqa_exact"
        },
        "requires_zero_sliding_window_for_saved_tensors": [
          "attn_weights"
        ]
      }
    },
    "block_contract": {
      "norm_type": "rmsnorm",
      "mlp_formula": "gate_up -> geglu -> down",
      "activation": "geglu",
      "qkv_bias": "from_weights"
    },
    "logits_contract": {
      "final_norm": "rmsnorm",
      "lm_head": "weight_tying",
      "logits_layout": "auto"
    },
    "quant_contract": {
      "kernel_select": "weight_dtype_registry",
      "activation_dtype": "fp32_or_q8_path",
      "per_tensor_mixed_quant": true
    },
    "runtime_invariants": {
      "required_call_args": {
        "kv_cache_batch_copy": [
          "activation:k_src",
          "activation:v_src",
          "output:k_dst",
          "output:v_dst",
          "dim:_kv_copy_bytes"
        ]
      }
    }
  },
  "kernels": {
    "rope_qk": "rope_forward_qk",
    "rope_init": "rope_precompute_cache_split"
  },
  "sequence": ["decoder"],
  "block_types": {
    "decoder": {
      "sequence": ["header", "body", "footer"],
      "header": [
        "bpe_tokenizer",
        "dense_embedding_lookup"
      ],
      "body": {
        "type": "dense",
        "ops": [
          "attn_norm",
          "qkv_proj",
          "qk_norm",
          "rope_qk",
          "attn_sliding",
          "out_proj",
          "post_attention_norm",
          "residual_add",
          "ffn_norm",
          "mlp_gate_up",
          "geglu",
          "mlp_down",
          "post_ffn_norm",
          "residual_add"
        ]
      },
      "footer": [
        "final_rmsnorm",
        "weight_tying",
        "logits"
      ]
    }
  }
}
