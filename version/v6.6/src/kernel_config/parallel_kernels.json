    },

    "gemv_fused_q5_0_bias": {
      "parallel_omp": {
        "function": "gemv_fused_q5_0_bias_parallel_omp",
        "params": ["y", "W", "x", "bias", "M", "K"],
        "requires": [],
        "speedup": "1.4-2.1x",
        "notes": "Same signature as serial — OpenMP handled internally, no wrapper needed"
      },
