  "spec": "spec19",
  "date": "2026-04-01",
  "title": "Spec19 Textbook Routing Mixture",
  "derived_from": {
    "frozen_raw_winner": "spec16_scene_bundle_l3_d192_h384_ctx768_r9",
    "repaired_baseline": "spec16_scene_bundle_l3_d192_h384_ctx768_r9 + deterministic repair",
    "diagnostic_branch": "spec17_scene_bundle_l3_d192_h384_ctx768_r4",
    "autopsy_report": "version/v7/reports/SPEC16_R12_AUTOPSY_2026-03-31.md",
    "spec17_r4_autopsy": "version/v7/reports/SPEC17_R4_CONTRAST_SCAFFOLD_AUTOPSY_2026-04-01.md",
    "training_plan": "docs/site/_pages/spec19-textbook-routing-mixture.html"
  },
  "objective": "Teach bounded-intent family and form routing with a textbook routebook and minimal-pair mixture before widening to style and topology inference, while preserving the frozen spec16 shared bundle contract.",
  "why_this_exists": [
    "Spec16 proved the shared bundle can be learned cleanly when the prompt contract stays explicit and deterministic.",
    "Spec17 fixed its scaffold process bugs but still ended with zero exactness on visible and hidden held-out splits, which means the remaining failure is a capability mismatch rather than a launch bug.",
    "Spec19 changes the dataset philosophy: preserve closure, make direct routebook rows and minimal pairs the center of mass, and only then widen to style and topology inference."
  ],
  "contracts": {
    "prompt_contract": {
      "primary_prompt": "[task:svg] [topic:<topic_id>] [goal:<goal_id>] [audience:<audience_id>] [OUT]",
      "controlled_hints": [
        "[emphasis:<hint>]",
        "[constraint:<compact|balanced|dense>]",
        "[content_pack:<brief|default|dense>]"
      ],
      "internal_scaffold_only": [
        "[layout:<family>]",
        "[form:<form>]"
      ],
      "disallowed_prompt_fields": [
        "theme",
        "tone",
        "density",
        "background",
        "topology counters",
        "raw SVG",
        "repair prose"
      ]
    },
    "output_contract": {
      "primary_surface": "Emit exactly one shared [bundle] scene_bundle.v1 only.",
      "external_payload": "Visible copy, facts, numbers, and labels remain in content.json.",
      "disallowed_outputs": [
        "raw SVG",
        "topic ids or prompt metadata inside the bundle",
        "asset-specific ids",
        "free-written prose",
        "family-specific lowerer syntax"
      ]
    },
    "decode_boundary": {
      "allowed_repairs": [
        "truncate at the first valid [/bundle]",
        "strip copied prompt or control tags outside the bundle",
        "dedupe singleton tags when family and form already match",
        "fill missing prompt-controlled fields only when family and form already match"
      ],
      "disallowed_repairs": [
        "change family",
        "change form",
        "guess a new style bundle",
        "re-emit a fresh bundle from the prompt without model evidence"
      ]
    }
  },
