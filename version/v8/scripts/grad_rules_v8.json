            {
              "name": "d_v",
              "kind": "grad_activation",
              "target_input": "v"
            },
        {
          "name": "d_scores",
          "kind": "aux",
          "tensor": "aux.d_scores",
          "shape_from_saved": "attn_weights"
        }
