#!/bin/bash
# =============================================================================
# CK-Engine Pre-Push Hook
# =============================================================================
# Runs essential tests before allowing push to remote.
# This catches issues that CI might miss due to resource constraints.
#
# Install: git config core.hooksPath .githooks
# Or:      ln -sf ../../.githooks/pre-push .git/hooks/pre-push
# =============================================================================

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo -e "${YELLOW}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${YELLOW}║           CK-Engine Pre-Push Validation                    ║${NC}"
echo -e "${YELLOW}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Allow skipping with --no-verify or CK_SKIP_PREPUSH=1
if [ -n "$CK_SKIP_PREPUSH" ]; then
    echo -e "${YELLOW}⚠️  Skipping pre-push tests (CK_SKIP_PREPUSH=1)${NC}"
    exit 0
fi

cd "$ROOT_DIR"

failed=0

# =============================================================================
# Test 1: Compilation
# =============================================================================
echo -e "${YELLOW}[1/4]${NC} Building CK-Engine..."
if make -j$(nproc) > /tmp/ck_build.log 2>&1; then
    echo -e "${GREEN}  ✓ Build successful${NC}"
else
    echo -e "${RED}  ✗ Build failed${NC}"
    echo "    See /tmp/ck_build.log for details"
    failed=1
fi

# =============================================================================
# Test 2: Quick kernel tests (if parity lib exists)
# =============================================================================
echo -e "${YELLOW}[2/4]${NC} Running kernel parity tests..."
if [ -f "build/libck_parity.so" ] || [ -f "libck_parity.so" ]; then
    # Ensure llama.cpp kernel test library exists (auto-build if missing)
    if [ ! -f "llama.cpp/libggml_kernel_test.so" ]; then
        echo -e "${YELLOW}  ↳ Building llama.cpp kernel test library...${NC}"
        if [ -d "llama.cpp" ]; then
            (cd llama.cpp && make -j$(nproc) > /tmp/ck_llama_build.log 2>&1) || true
            (cd llama.cpp && g++ -shared -fPIC -o libggml_kernel_test.so \
                tests/test-kernel-parity.cpp \
                -I ggml/include -I ggml/src \
                -L build -lggml -lm -lpthread > /tmp/ck_llama_kernel_test.log 2>&1) || true
        fi
    fi

    if python3 scripts/test_kernels_vs_llamacpp.py --quick > /tmp/ck_parity.log 2>&1; then
        echo -e "${GREEN}  ✓ Kernel parity tests passed${NC}"
    else
        # If Intel runtime or llama test lib missing, mark as skipped instead of fail
        if grep -qiE "libimf.so|libggml_kernel_test.so|Could not load llama.cpp kernel test library" /tmp/ck_parity.log; then
            echo -e "${YELLOW}  ⚠ Skipped (missing runtime or llama.cpp test lib)${NC}"
        else
            echo -e "${RED}  ✗ Kernel parity tests failed${NC}"
            echo "    See /tmp/ck_parity.log for details"
            failed=1
        fi
    fi
else
    echo -e "${YELLOW}  ⚠ Skipped (no parity library - build with: make libck_parity.so)${NC}"
fi

# =============================================================================
# Test 3: E2E inference test
# =============================================================================
echo -e "${YELLOW}[3/4]${NC} Running E2E inference test..."

# Prefer explicit HF GGUF URLs (Gemma3 -> Qwen3 -> Qwen2)
HF_CANDIDATES=(
  "hf://unsloth/gemma-3-270m-it-GGUF/gemma-3-270m-it-Q5_K_M.gguf"
  "hf://Qwen/Qwen3-0.6B-GGUF/Qwen3-0.6B-Q8_0.gguf"
  "hf://Qwen/Qwen2-0.5B-Instruct-GGUF/qwen2-0_5b-instruct-q4_k_m.gguf"
)

PROMPTS=(
  "Hello! Reply with a single short sentence."
  "Give a tiny C function that returns 42."
  "Give a tiny Python function that returns 42."
  "Give a tiny SQL query that selects the number 42."
)

RUNNER=""
if [ -f "version/v6.6/scripts/ck_run_v6_6.py" ]; then
    RUNNER="version/v6.6/scripts/ck_run_v6_6.py"
elif [ -f "scripts/v6.6/ck_run_v6_6.py" ]; then
    RUNNER="scripts/v6.6/ck_run_v6_6.py"
fi

if [ -n "$RUNNER" ]; then
    e2e_ok=0
    e2e_fail=0
    for HF in "${HF_CANDIDATES[@]}"; do
        echo -e "${YELLOW}  ↳ E2E model: ${HF}${NC}"
        echo -e "${YELLOW}    Prompts:${NC}"
        for P in "${PROMPTS[@]}"; do
            echo -e "${YELLOW}    - ${P}${NC}"
        done

        for P in "${PROMPTS[@]}"; do
            OUTPUT=$(timeout 180 python3 "$RUNNER" run "$HF" \
                --prompt "$P" \
                --max-tokens 5 \
                --context-len 128 \
                --force-compile 2>&1 || true)

            if echo "$OUTPUT" | grep -qiE "Missing attention.head_count|GGUFError"; then
                echo -e "${YELLOW}  ⚠ Skipped (GGUF metadata missing)${NC}"
                e2e_fail=1
                break
            fi
            if echo "$OUTPUT" | grep -qiE "segfault|SIGSEGV|Traceback|assertion failed|abort"; then
                echo -e "${RED}  ✗ E2E inference crashed${NC}"
                echo "$OUTPUT" | tail -5
                failed=1
                e2e_fail=1
                break
            elif echo "$OUTPUT" | grep -qiE "mmap failed|Cannot allocate memory|out of memory|ENOMEM"; then
                echo -e "${RED}  ✗ E2E inference failed (insufficient memory)${NC}"
                echo "$OUTPUT" | tail -3
                failed=1
                e2e_fail=1
                break
            elif echo "$OUTPUT" | grep -qE "tok/s|Response:|Generated"; then
                e2e_ok=1
            else
                echo -e "${YELLOW}  ⚠ E2E inference unclear (check output)${NC}"
                echo "$OUTPUT" | tail -3
                e2e_fail=1
                break
            fi

            # Basic perf warning (non-fatal)
            if command -v rg >/dev/null 2>&1; then
                tok_s=$(echo "$OUTPUT" | rg -o "([0-9]+\\.?[0-9]*)\\s*tok/s" | head -1 | rg -o "[0-9]+\\.?[0-9]*")
            else
                tok_s=$(echo "$OUTPUT" | grep -oE "([0-9]+\\.?[0-9]*)[[:space:]]*tok/s" | head -1 | grep -oE "[0-9]+\\.?[0-9]*")
            fi
            if [ -n "$tok_s" ]; then
                warn=$(python3 - <<PY
tok = float("$tok_s")
print("1" if tok < 2.0 else "0")
PY
)
                if [ "$warn" = "1" ]; then
                    echo -e "${YELLOW}  ⚠ Low throughput: ${tok_s} tok/s${NC}"
                fi
            fi
        done

        if [ "$e2e_fail" -ne 0 ] || [ "$failed" -ne 0 ]; then
            break
        fi
        if [ "$e2e_ok" -eq 0 ]; then
            e2e_fail=1
            break
        fi
    done

    if [ "$failed" -eq 0 ] && [ "$e2e_ok" -eq 0 ]; then
        echo -e "${RED}  ✗ E2E inference failed (no usable HF model)${NC}"
        failed=1
    elif [ "$failed" -eq 0 ] && [ "$e2e_fail" -ne 0 ]; then
        echo -e "${RED}  ✗ E2E inference failed (one or more models/prompts failed)${NC}"
        failed=1
    else
        echo -e "${GREEN}  ✓ E2E inference completed for all models${NC}"
    fi
else
    echo -e "${YELLOW}  ⚠ Skipped (no runner script found)${NC}"
fi

# =============================================================================
# Test 4: v6.6 required release gate
# =============================================================================
echo -e "${YELLOW}[4/4]${NC} Running v6.6 release gate..."
if make --no-print-directory v6.6-gate > /tmp/ck_v66_gate.log 2>&1; then
    echo -e "${GREEN}  ✓ v6.6 gate passed (matrix-smoke + strict parity + long decode)${NC}"
else
    echo -e "${RED}  ✗ v6.6 gate failed${NC}"
    echo "    See /tmp/ck_v66_gate.log for details"
    failed=1
fi

# =============================================================================
# Summary
# =============================================================================
echo ""
if [ $failed -eq 0 ]; then
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}  ✓ All pre-push checks passed!${NC}"
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    exit 0
else
    echo -e "${RED}════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  ✗ Pre-push checks failed!${NC}"
    echo -e "${RED}════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "To push anyway: ${YELLOW}git push --no-verify${NC}"
    echo -e "Or set: ${YELLOW}export CK_SKIP_PREPUSH=1${NC}"
    echo ""
    exit 1
fi
