        "partition_dim": "T",
        "param_style": "range",
        "range": {"min_chunk": 1},
        "notes": "Process tokens in parallel; each thread normalizes one or more tokens."
      },
      {
        "name": "feature",
        "partition_dim": "E",
        "param_style": "range",
        "range": {"min_chunk": 64, "align_bytes": 32, "allow_tail": true},
        "notes": "Parallelize across embed dimension; reduction needed for mean/variance."
