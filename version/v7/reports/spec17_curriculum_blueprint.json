  "title": "Spec17 Bounded Intent Bridge",
  "derived_from": {
    "frozen_raw_winner": "spec16_scene_bundle_l3_d192_h384_ctx768_r9",
    "repaired_baseline": "spec16_scene_bundle_l3_d192_h384_ctx768_r9 + deterministic repair",
    "blocked_repair_line": [
      "spec16_scene_bundle_l3_d192_h384_ctx768_r10",
      "spec16_scene_bundle_l3_d192_h384_ctx768_r11",
      "spec16_scene_bundle_l3_d192_h384_ctx768_r12"
    ],
    "autopsy_report": "version/v7/reports/SPEC16_R12_AUTOPSY_2026-03-31.md",
    "spec17_r1_canary_autopsy": "version/v7/reports/SPEC17_R1_CANARY_AUTOPSY_2026-04-01.md"
  },
  "objective": "Teach a bounded intent prompt to select a shared spec16 scene bundle without reintroducing free-form prose, raw SVG, or repair-language curriculum churn.",
  "why_this_exists": [
    "Spec16 proved the shared bundle can be learned under explicit control when the curriculum is clean and balanced.",
    "Spec16 also showed that post-hoc narrow raw repair rungs regress more often than they help once a strong raw winner exists.",
    "Spec17 should therefore be a true new branch: weaker prompt control over the same shared bundle contract, with predictable failure frontiers designed into the first curriculum."
  ],
  "contracts": {
    "prompt_contract": {
      "primary_prompt": "[task:svg] [topic:<topic_id>] [goal:<goal_id>] [audience:<audience_id>] [OUT]",
      "controlled_hints": [
        "[emphasis:<hint>]",
        "[constraint:<compact|balanced|dense>]",
        "[content_pack:<brief|default|dense>]"
      ],
      "disallowed_prompt_fields": [
        "layout",
        "family",
        "form",
        "theme",
        "tone",
        "density",
        "background",
        "topology counters"
      ]
    },
    "output_contract": {
      "primary_surface": "Emit exactly one shared [bundle] scene_bundle.v1 only.",
      "external_payload": "Visible copy, facts, numbers, and labels remain in content.json.",
      "disallowed_outputs": [
        "raw SVG",
        "topic ids or prompt metadata inside the bundle",
        "asset-specific ids",
        "free-written prose",
        "family-specific lowerer syntax"
      ]
    },
    "decode_boundary": {
      "allowed_repairs": [
        "truncate at the first valid [/bundle]",
        "strip copied prompt/control tags outside the bundle",
        "dedupe singleton tags when family and form already match",
        "fill missing prompt-controlled fields only when family and form already match"
      ],
      "disallowed_repairs": [
        "change family",
        "change form",
        "guess a new style bundle",
        "re-emit a fresh bundle from the prompt without model evidence"
      ]
    }
  },
