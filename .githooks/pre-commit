#!/bin/bash
# =============================================================================
# CK-Engine Pre-Commit Hook
# =============================================================================
# Runs the fast inference-family regression gate for staged runtime/regression
# changes. This keeps the heavy family matrix close to the edit that caused it
# without forcing docs-only commits to wait on model bring-up.
#
# Install: git config core.hooksPath .githooks
# Or:      ln -sf ../../.githooks/pre-commit .git/hooks/pre-commit
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo -e "${YELLOW}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${YELLOW}║           CK-Engine Pre-Commit Validation                  ║${NC}"
echo -e "${YELLOW}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

if [ -n "${CK_SKIP_PRECOMMIT:-}" ]; then
    echo -e "${YELLOW}⚠️  Skipping pre-commit checks (CK_SKIP_PRECOMMIT=1)${NC}"
    exit 0
fi

cd "$ROOT_DIR"

mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACMR)

if [ ${#STAGED_FILES[@]} -eq 0 ]; then
    echo -e "${YELLOW}⚠️  No staged files; skipping pre-commit regression${NC}"
    exit 0
fi

should_run_v7_regression=0
should_run_v8_regression=0
for path in "${STAGED_FILES[@]}"; do
    case "$path" in
        Makefile|.githooks/pre-commit|.githooks/pre-push|.github/workflows/nightly.yml)
            should_run_v7_regression=1
            should_run_v8_regression=1
            ;;
        scripts/*|src/*|tests/*)
            should_run_v7_regression=1
            should_run_v8_regression=1
            ;;
        version/v7/scripts/*|version/v7/templates/*|version/v7/regression/*|version/v7/test_assets/*|version/v7/src/*|version/v7/kernel_maps/*|version/v7/README.md)
            should_run_v7_regression=1
            ;;
        version/v8/scripts/*|version/v8/templates/*|version/v8/regression/*|version/v8/test_assets/*|version/v8/src/*|version/v8/kernel_maps/*|version/v8/README.md)
            should_run_v8_regression=1
            ;;
    esac
    if [ "$should_run_v7_regression" = "1" ] && [ "$should_run_v8_regression" = "1" ]; then
        break
    fi
done

if [ "$should_run_v7_regression" != "1" ] && [ "$should_run_v8_regression" != "1" ]; then
    echo -e "${GREEN}✓ Staged changes do not affect v7/v8 runtime or regression paths; skipping fast regression${NC}"
    exit 0
fi

RUN_ROOT="${CK_PRECOMMIT_RUN_ROOT:-/tmp/ck-precommit-regression/runs}"
REPORT_ROOT="${CK_PRECOMMIT_REPORT_ROOT:-/tmp/ck-precommit-regression/reports}"
CACHE_ROOT="${CK_PRECOMMIT_CACHE_ROOT:-/tmp/ck-precommit-regression/cache/models}"
SNAPSHOT_PREFIX="${CK_PRECOMMIT_SNAPSHOT_PREFIX:-/tmp/ck-precommit-snapshot}"
SNAPSHOT_PARENT=""
SNAPSHOT_DIR=""

cleanup_snapshot() {
    if [ -n "${SNAPSHOT_PARENT:-}" ] && [ -d "${SNAPSHOT_PARENT}" ]; then
        rm -rf "$SNAPSHOT_PARENT"
    fi
}

trap cleanup_snapshot EXIT

build_staged_snapshot() {
    SNAPSHOT_PARENT="$(mktemp -d "${SNAPSHOT_PREFIX}.XXXXXX")"
    SNAPSHOT_DIR="${SNAPSHOT_PARENT}/worktree"
    git clone --shared --quiet --no-hardlinks "$ROOT_DIR" "$SNAPSHOT_DIR" >/dev/null 2>&1
    git -C "$SNAPSHOT_DIR" checkout --detach HEAD >/dev/null 2>&1
    if [ -d "$ROOT_DIR/.venv" ] && [ ! -e "$SNAPSHOT_DIR/.venv" ]; then
        ln -s "$ROOT_DIR/.venv" "$SNAPSHOT_DIR/.venv"
    fi
    if [ -d "$ROOT_DIR/llama.cpp/include" ] && [ ! -d "$SNAPSHOT_DIR/llama.cpp/include" ]; then
        rm -rf "$SNAPSHOT_DIR/llama.cpp"
        ln -s "$ROOT_DIR/llama.cpp" "$SNAPSHOT_DIR/llama.cpp"
    fi
    if git -C "$ROOT_DIR" rev-parse --verify HEAD >/dev/null 2>&1; then
        git -C "$ROOT_DIR" diff --cached --binary --submodule=diff HEAD -- | git -C "$SNAPSHOT_DIR" apply --index --whitespace=nowarn
    else
        git -C "$ROOT_DIR" diff --cached --binary --submodule=diff | git -C "$SNAPSHOT_DIR" apply --index --whitespace=nowarn
    fi
}

seed_precommit_cache_from() {
    local source_models="$1"
    if [ ! -d "$source_models" ]; then
        return
    fi
    local entry
    local name
    for entry in "$source_models"/* "$source_models"/.*; do
        name="$(basename "$entry")"
        case "$name" in
            .|..)
                continue
                ;;
        esac
        if [ ! -e "$CACHE_ROOT/$name" ]; then
            ln -s "$entry" "$CACHE_ROOT/$name" 2>/dev/null || true
        fi
    done
}

seed_precommit_cache() {
    mkdir -p "$CACHE_ROOT"
    # Prefer native v8 cache entries first, then fall back to legacy v7 cache reuse.
    seed_precommit_cache_from "$HOME/.cache/ck-engine-v8/models"
    seed_precommit_cache_from "$HOME/.cache/ck-engine-v7/models"
}

echo -e "${YELLOW}Running staged fast regression suites...${NC}"
echo -e "${YELLOW}  ↳ run root: ${RUN_ROOT}${NC}"
echo -e "${YELLOW}  ↳ report root: ${REPORT_ROOT}${NC}"
echo -e "${YELLOW}  ↳ cache root: ${CACHE_ROOT}${NC}"
echo -e "${YELLOW}  ↳ staged snapshot: ${SNAPSHOT_PREFIX}.XXXXXX${NC}"
if [ "$should_run_v7_regression" = "1" ]; then
    echo -e "${YELLOW}  ↳ enabled: v7-regression-fast${NC}"
fi
if [ "$should_run_v8_regression" = "1" ]; then
    echo -e "${YELLOW}  ↳ enabled: v8-regression-fast${NC}"
fi

build_staged_snapshot
seed_precommit_cache

if [ "$should_run_v7_regression" = "1" ]; then
    echo -e "${YELLOW}Running v7-kernel-map-contracts in staged snapshot...${NC}"
    if ! make -C "$SNAPSHOT_DIR" v7-kernel-map-contracts > /tmp/ck_precommit_kernel_maps.log 2>&1; then
        echo -e "${RED}✗ v7-kernel-map-contracts failed${NC}"
        echo "  See /tmp/ck_precommit_kernel_maps.log for details"
        tail -40 /tmp/ck_precommit_kernel_maps.log || true
        exit 1
    fi
    echo -e "${GREEN}✓ v7-kernel-map-contracts passed${NC}"
fi

if [ "$should_run_v7_regression" = "1" ]; then
    if ! CK_CACHE_DIR="${CACHE_ROOT}" make -C "$SNAPSHOT_DIR" v7-regression-fast REGRESSION_ARGS="--run-root ${RUN_ROOT}/v7 --report-root ${REPORT_ROOT}/v7" > /tmp/ck_precommit_regression_v7.log 2>&1; then
        echo -e "${RED}✗ v7-regression-fast failed${NC}"
        echo "  See /tmp/ck_precommit_regression_v7.log for details"
        tail -40 /tmp/ck_precommit_regression_v7.log || true
        exit 1
    fi
    echo -e "${GREEN}✓ v7-regression-fast passed${NC}"
fi

if [ "$should_run_v8_regression" = "1" ]; then
    if ! CK_CACHE_DIR="${CACHE_ROOT}" make -C "$SNAPSHOT_DIR" v8-regression-fast REGRESSION_ARGS="--run-root ${RUN_ROOT}/v8 --report-root ${REPORT_ROOT}/v8" > /tmp/ck_precommit_regression_v8.log 2>&1; then
        echo -e "${RED}✗ v8-regression-fast failed${NC}"
        echo "  See /tmp/ck_precommit_regression_v8.log for details"
        tail -40 /tmp/ck_precommit_regression_v8.log || true
        exit 1
    fi
    echo -e "${GREEN}✓ v8-regression-fast passed${NC}"
fi

exit 0
