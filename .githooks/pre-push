#!/bin/bash
# =============================================================================
# CK-Engine Pre-Push Hook
# =============================================================================
# Runs essential tests before allowing push to remote.
# This catches issues that CI might miss due to resource constraints.
#
# Install: git config core.hooksPath .githooks
# Or:      ln -sf ../../.githooks/pre-push .git/hooks/pre-push
# =============================================================================

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo -e "${YELLOW}╔════════════════════════════════════════════════════════════╗${NC}"
echo -e "${YELLOW}║           CK-Engine Pre-Push Validation                    ║${NC}"
echo -e "${YELLOW}╚════════════════════════════════════════════════════════════╝${NC}"
echo ""

# Allow skipping with --no-verify or CK_SKIP_PREPUSH=1
if [ -n "$CK_SKIP_PREPUSH" ]; then
    echo -e "${YELLOW}⚠️  Skipping pre-push tests (CK_SKIP_PREPUSH=1)${NC}"
    exit 0
fi

cd "$ROOT_DIR"

failed=0
declare -A CK_PUSH_SHA_SEEN=()
PUSH_TARGETS=()
while read -r local_ref local_sha remote_ref remote_sha; do
    if [ -z "${local_sha:-}" ] || [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi
    if [ -n "${CK_PUSH_SHA_SEEN[$local_sha]:-}" ]; then
        continue
    fi
    CK_PUSH_SHA_SEEN[$local_sha]=1
    PUSH_TARGETS+=("$local_sha")
done
if [ ${#PUSH_TARGETS[@]} -eq 0 ]; then
    PUSH_TARGETS=("HEAD")
fi

# =============================================================================
# Test 0: Submodule pin sanity (prevents CI checkout breakage)
# =============================================================================
echo -e "${YELLOW}[0/6]${NC} Validating submodule pins..."
printf '' > /tmp/ck_submodule_pins.log
submodule_pin_ok=1
for push_target in "${PUSH_TARGETS[@]}"; do
    if ! python3 scripts/validate_submodule_pins.py --treeish "$push_target" >> /tmp/ck_submodule_pins.log 2>&1; then
        submodule_pin_ok=0
        break
    fi
done
if [ "$submodule_pin_ok" = "1" ]; then
    echo -e "${GREEN}  ✓ Submodule pins reachable on configured remotes${NC}"
else
    echo -e "${RED}  ✗ Submodule pin validation failed${NC}"
    tail -20 /tmp/ck_submodule_pins.log
    exit 1
fi

# =============================================================================
# Test 0.5: Visualizer health (fast static analysis, no build needed)
# =============================================================================
echo -e "${YELLOW}[0.5/6]${NC} Visualizer HTML/JS health check..."
if python3 version/v7/scripts/test_visualizer_health_v7.py --source --quiet > /tmp/ck_visualizer_health.log 2>&1 \
   && python3 version/v7/scripts/test_visualizer_js_units_v7.py --quiet >> /tmp/ck_visualizer_health.log 2>&1; then
    echo -e "${GREEN}  ✓ Visualizer health passed${NC}"
else
    echo -e "${RED}  ✗ Visualizer health failed (tabs/functions/contracts)${NC}"
    tail -20 /tmp/ck_visualizer_health.log
    failed=1
fi

# Toolchain policy:
# - Prefer Intel path when available (icx/icpx + oneAPI runtime) for parity with perf builds.
# - Fall back to portable gcc path when Intel runtime is unavailable.
INTEL_SETVARS="${CK_PREPUSH_INTEL_SETVARS:-/opt/intel/oneapi/setvars.sh}"
if [ -z "${CK_PREPUSH_USE_INTEL:-}" ]; then
    if command -v icx >/dev/null 2>&1 && command -v icpx >/dev/null 2>&1 && [ -f "$INTEL_SETVARS" ]; then
        CK_PREPUSH_USE_INTEL=1
    else
        CK_PREPUSH_USE_INTEL=0
    fi
fi

if [ "${CK_PREPUSH_USE_INTEL}" = "1" ]; then
    if [ -f "$INTEL_SETVARS" ]; then
        # shellcheck disable=SC1090
        source "$INTEL_SETVARS" >/tmp/ck_prepush_setvars.log 2>&1 || true
    fi
    # Harden runtime linker path for Python/ctypes loaders that need Intel libs.
    # setvars.sh can be a no-op if already sourced; always prepend known compiler paths.
    INTEL_COMPILER_LIB="/opt/intel/oneapi/compiler/latest/lib"
    INTEL_COMPILER_OPT_LIB="/opt/intel/oneapi/compiler/latest/opt/compiler/lib"
    if [ -d "$INTEL_COMPILER_LIB" ]; then
        export LD_LIBRARY_PATH="$INTEL_COMPILER_LIB:$INTEL_COMPILER_OPT_LIB:${LD_LIBRARY_PATH:-}"
    fi
    export CC="${CK_PREPUSH_CC:-icx}"
    export CXX="${CK_PREPUSH_CXX:-icpx}"
    export CK_V6_COMPILER="${CK_V6_COMPILER:-icx}"
    export CK_V7_COMPILER="${CK_V7_COMPILER:-icx}"
    echo -e "${YELLOW}  ↳ Toolchain: CC=${CC} CXX=${CXX} (Intel mode)${NC}"
else
    export CC="${CK_PREPUSH_CC:-gcc}"
    export CXX="${CK_PREPUSH_CXX:-g++}"
    export CK_V6_COMPILER="${CK_V6_COMPILER:-gcc}"
    export CK_V7_COMPILER="${CK_V7_COMPILER:-gcc}"
    export USE_NATIVE=1
    unset USE_MKL
    unset USE_ONEDNN
    echo -e "${YELLOW}  ↳ Toolchain: CC=${CC} CXX=${CXX} (portable mode)${NC}"
    echo -e "${YELLOW}    set CK_PREPUSH_USE_INTEL=1 to keep Intel compiler/runtime path${NC}"
fi

# =============================================================================
# Test 1: Compilation
# =============================================================================
echo -e "${YELLOW}[1/6]${NC} Building CK-Engine..."
if make -j$(nproc) > /tmp/ck_build.log 2>&1; then
    echo -e "${GREEN}  ✓ Build successful${NC}"
else
    echo -e "${RED}  ✗ Build failed${NC}"
    echo "    See /tmp/ck_build.log for details"
    failed=1
fi

# =============================================================================
# Test 2: Quick kernel tests (if parity lib exists)
# =============================================================================
echo -e "${YELLOW}[2/6]${NC} Running kernel parity tests..."
if [ -f "build/libck_parity.so" ] || [ -f "libck_parity.so" ]; then
    # Ensure llama.cpp kernel test library exists (auto-build if missing)
    if [ ! -f "llama.cpp/libggml_kernel_test.so" ]; then
        echo -e "${YELLOW}  ↳ Building llama.cpp kernel test library...${NC}"
        if [ -d "llama.cpp" ]; then
            (cd llama.cpp && make -j$(nproc) > /tmp/ck_llama_build.log 2>&1) || true
            (cd llama.cpp && g++ -shared -fPIC -o libggml_kernel_test.so \
                tests/test-kernel-parity.cpp \
                -I ggml/include -I ggml/src \
                -L build -lggml -lm -lpthread > /tmp/ck_llama_kernel_test.log 2>&1) || true
        fi
    fi

    if python3 scripts/test_kernels_vs_llamacpp.py --quick > /tmp/ck_parity.log 2>&1; then
        echo -e "${GREEN}  ✓ Kernel parity tests passed${NC}"
    else
        # If Intel runtime or llama test lib missing, mark as skipped instead of fail
        if grep -qiE "libimf.so|libggml_kernel_test.so|Could not load llama.cpp kernel test library" /tmp/ck_parity.log; then
            echo -e "${YELLOW}  ⚠ Skipped (missing runtime or llama.cpp test lib)${NC}"
        else
            echo -e "${RED}  ✗ Kernel parity tests failed${NC}"
            echo "    See /tmp/ck_parity.log for details"
            failed=1
        fi
    fi
else
    echo -e "${YELLOW}  ⚠ Skipped (no parity library - build with: make libck_parity.so)${NC}"
fi

# =============================================================================
# Test 3: E2E inference test
# =============================================================================
echo -e "${YELLOW}[3/6]${NC} Running E2E inference test..."

# Candidate models for E2E smoke:
# 1) explicit override, 2) local cache, 3) HF GGUF URL fallback.
MODEL_CANDIDATES=()
if [ -n "${CK_E2E_MODEL:-}" ]; then
  MODEL_CANDIDATES+=("${CK_E2E_MODEL}")
fi

LOCAL_CANDIDATES=(
  "$HOME/.cache/ck-engine-v7/models/unsloth--gemma-3-270m-it-GGUF"
  "$HOME/.cache/ck-engine-v7/models/Qwen--Qwen3-0.6B-GGUF"
  "$HOME/.cache/ck-engine-v7/models/Qwen--Qwen2-0.5B-Instruct-GGUF"
)
for C in "${LOCAL_CANDIDATES[@]}"; do
  if [ -d "$C" ]; then
    GGUF_LOCAL=$(find "$C" -maxdepth 1 -type f -name "*.gguf" 2>/dev/null | sort | head -1 || true)
    if [ -n "$GGUF_LOCAL" ] && [ -f "$GGUF_LOCAL" ]; then
      MODEL_CANDIDATES+=("$GGUF_LOCAL")
    elif [ -f "$C/config.json" ]; then
      MODEL_CANDIDATES+=("$C")
    fi
  fi
done

HF_CANDIDATES=(
  "hf://unsloth/gemma-3-270m-it-GGUF/gemma-3-270m-it-Q5_K_M.gguf"
  "hf://Qwen/Qwen3-0.6B-GGUF/Qwen3-0.6B-Q8_0.gguf"
  "hf://Qwen/Qwen2-0.5B-Instruct-GGUF/qwen2-0_5b-instruct-q4_k_m.gguf"
)
for C in "${HF_CANDIDATES[@]}"; do
  MODEL_CANDIDATES+=("$C")
done

PROMPTS=(
  "Hello! Reply with a single short sentence."
  "Give a tiny C function that returns 42."
  "Give a tiny Python function that returns 42."
  "Give a tiny SQL query that selects the number 42."
)

RUNNER=""
if [ -f "version/v6.6/scripts/ck_run_v6_6.py" ]; then
    RUNNER="version/v6.6/scripts/ck_run_v6_6.py"
elif [ -f "scripts/v6.6/ck_run_v6_6.py" ]; then
    RUNNER="scripts/v6.6/ck_run_v6_6.py"
fi

if [ -n "$RUNNER" ]; then
    e2e_ok=0
    e2e_network_skip=0
    e2e_permission_skip=0
    for MODEL in "${MODEL_CANDIDATES[@]}"; do
        candidate_status="ok"
        echo -e "${YELLOW}  ↳ E2E model: ${MODEL}${NC}"
        echo -e "${YELLOW}    Prompts:${NC}"
        for P in "${PROMPTS[@]}"; do
            echo -e "${YELLOW}    - ${P}${NC}"
        done

        for P in "${PROMPTS[@]}"; do
            RUN_ARGS=(
              run "$MODEL"
              --prompt "$P"
              --max-tokens 5
              --context-len 128
            )
            # Keep pre-push E2E portable and non-destructive by default.
            if [ "${CK_E2E_FORCE_COMPILE:-0}" = "1" ]; then
                RUN_ARGS+=(--force-compile)
            fi
            OUTPUT=$(timeout 180 python3 "$RUNNER" "${RUN_ARGS[@]}" 2>&1 || true)

            if echo "$OUTPUT" | grep -qiE "Temporary failure in name resolution|Connection timed out|Could not resolve host|No route to host|network is unreachable|HTTPError|httpx|client has been closed"; then
                echo -e "${YELLOW}  ⚠ Skipped candidate (network unavailable): ${MODEL}${NC}"
                candidate_status="network_skip"
                e2e_network_skip=1
                break
            fi
            if echo "$OUTPUT" | grep -qiE "Permission denied|Errno 13"; then
                echo -e "${YELLOW}  ⚠ Skipped candidate (cache permission issue): ${MODEL}${NC}"
                candidate_status="permission_skip"
                e2e_permission_skip=1
                break
            fi
            if echo "$OUTPUT" | grep -qiE "Missing attention.head_count|GGUFError"; then
                echo -e "${YELLOW}  ⚠ Skipped candidate (GGUF metadata missing): ${MODEL}${NC}"
                candidate_status="incompatible"
                break
            fi
            if echo "$OUTPUT" | grep -qiE "segfault|SIGSEGV|Traceback|assertion failed|abort"; then
                echo -e "${RED}  ✗ E2E inference crashed${NC}"
                echo "$OUTPUT" | tail -5
                failed=1
                candidate_status="hard_fail"
                break
            elif echo "$OUTPUT" | grep -qiE "mmap failed|Cannot allocate memory|out of memory|ENOMEM"; then
                echo -e "${RED}  ✗ E2E inference failed (insufficient memory)${NC}"
                echo "$OUTPUT" | tail -3
                failed=1
                candidate_status="hard_fail"
                break
            elif echo "$OUTPUT" | grep -qE "tok/s|Response:|Generated"; then
                e2e_ok=1
            else
                echo -e "${YELLOW}  ⚠ E2E inference unclear (check output)${NC}"
                echo "$OUTPUT" | tail -3
                candidate_status="hard_fail"
                break
            fi

            # Basic perf warning (non-fatal)
            if command -v rg >/dev/null 2>&1; then
                tok_s=$(echo "$OUTPUT" | rg -o "([0-9]+\\.?[0-9]*)\\s*tok/s" | head -1 | rg -o "[0-9]+\\.?[0-9]*" || true)
            else
                tok_s=$(echo "$OUTPUT" | grep -oE "([0-9]+\\.?[0-9]*)[[:space:]]*tok/s" | head -1 | grep -oE "[0-9]+\\.?[0-9]*" || true)
            fi
            if [ -n "$tok_s" ]; then
                warn=$(python3 - <<PY
tok = float("$tok_s")
print("1" if tok < 2.0 else "0")
PY
)
                if [ "$warn" = "1" ]; then
                    echo -e "${YELLOW}  ⚠ Low throughput: ${tok_s} tok/s${NC}"
                fi
            fi
        done

        if [ "$failed" -ne 0 ]; then
            break
        fi
        if [ "$candidate_status" = "ok" ] && [ "$e2e_ok" -eq 1 ]; then
            break
        fi
    done

    if [ "$failed" -ne 0 ]; then
        :
    elif [ "$e2e_ok" -eq 1 ]; then
        echo -e "${GREEN}  ✓ E2E inference passed${NC}"
    elif [ "$e2e_permission_skip" -ne 0 ]; then
        echo -e "${YELLOW}  ⚠ E2E inference skipped (cache permission issue and no candidate passed)${NC}"
    elif [ "$e2e_network_skip" -ne 0 ]; then
        echo -e "${YELLOW}  ⚠ E2E inference skipped (network unavailable and no local candidate passed)${NC}"
    elif [ "$e2e_ok" -eq 0 ]; then
        echo -e "${RED}  ✗ E2E inference failed (no usable candidate)${NC}"
        failed=1
    fi
else
    echo -e "${YELLOW}  ⚠ Skipped (no runner script found)${NC}"
fi

# =============================================================================
# Test 4: v6.6 required release gate
# =============================================================================
echo -e "${YELLOW}[4/6]${NC} Running v6.6 release gate..."
V66_PREPUSH_CACHE="${CK_V66_PREPUSH_CACHE_DIR:-$HOME/.cache/ck-engine-v6.6/models_prepush}"
V66_PREPUSH_CLEAN="${CK_V66_PREPUSH_CLEAN:-1}"
V66_PREPUSH_FULL_GATE="${CK_PREPUSH_V66_FULL_GATE:-0}"
V66_PY="$ROOT_DIR/.venv/bin/python"
if [ ! -x "$V66_PY" ]; then
    V66_PY="$(command -v python3)"
fi
if [ "$V66_PREPUSH_CLEAN" = "1" ] && [ -d "$V66_PREPUSH_CACHE" ]; then
    rm -rf "$V66_PREPUSH_CACHE"
fi
mkdir -p "$V66_PREPUSH_CACHE"

if [ "$V66_PREPUSH_FULL_GATE" = "1" ]; then
    if CK_CACHE_DIR="$V66_PREPUSH_CACHE" make --no-print-directory v6.6-gate > /tmp/ck_v66_gate.log 2>&1; then
        echo -e "${GREEN}  ✓ v6.6 gate passed (full gate)${NC}"
    else
        echo -e "${RED}  ✗ v6.6 gate failed${NC}"
        echo "    See /tmp/ck_v66_gate.log for details"
        failed=1
    fi
else
    # Stable pre-push v6.6 gate:
    # - Keep full structural checks
    # - Use build/artifact matrix (step [3/5] already does runtime smoke)
    # - Avoid flaky stale-artifact smoke failures in shared caches
    # - Treat legacy v6.6 parity as warning-only while v6.6 is being phased out
    if (
        make --no-print-directory v6.6-kernel-map-gate &&
        "$V66_PY" version/v6.6/scripts/validate_tooling_contracts.py --strict --json-out version/v6.6/tools/contract_report_latest.json &&
        CK_CACHE_DIR="$V66_PREPUSH_CACHE" "$V66_PY" version/v6.6/scripts/validate_model_matrix_v6_6.py --allow-download --require-all --skip-static-contracts --json-out version/v6.6/tools/model_matrix_report_latest.json &&
        (
            CK_CACHE_DIR="$V66_PREPUSH_CACHE" "$V66_PY" version/v6.6/scripts/validate_parity_matrix_v6_6.py --allow-download --json-out version/v6.6/tools/parity_matrix_report_latest.json ||
            {
                echo "[warn] v6.6 parity matrix had issues; continuing because v6.6 parity is legacy/decommissioning"
                echo "[warn] See version/v6.6/tools/parity_matrix_report_latest.json for details"
            }
        ) &&
        CK_CACHE_DIR="$V66_PREPUSH_CACHE" "$V66_PY" version/v6.6/scripts/validate_long_decode_stability_v6_6.py --allow-download --require-all --json-out version/v6.6/tools/long_decode_report_latest.json
    ) > /tmp/ck_v66_gate.log 2>&1; then
        echo -e "${GREEN}  ✓ v6.6 gate passed (stable pre-push profile)${NC}"
    else
        echo -e "${RED}  ✗ v6.6 gate failed${NC}"
        echo "    See /tmp/ck_v66_gate.log for details"
        failed=1
    fi
fi

# =============================================================================
# Test 5: v7 inference gate (generate/compile smoke)
# =============================================================================
echo -e "${YELLOW}[5/6]${NC} Running v7 inference gate..."
V7_MODEL_PREPUSH="${CK_V7_MODEL:-Qwen/Qwen3-0.6B}"
if make --no-print-directory v7-infer-gate V7_MODEL="$V7_MODEL_PREPUSH" > /tmp/ck_v7_infer_gate.log 2>&1; then
    echo -e "${GREEN}  ✓ v7 inference gate passed (${V7_MODEL_PREPUSH})${NC}"
else
    if grep -qiE "timed out|Temporary failure in name resolution|Connection timed out|Could not resolve host|SSL|HTTP|No route to host|network" /tmp/ck_v7_infer_gate.log; then
        echo -e "${YELLOW}  ⚠ v7 inference gate skipped (network unavailable). Set CK_V7_MODEL to a local cached model to enforce.${NC}"
    else
        echo -e "${RED}  ✗ v7 inference gate failed${NC}"
        echo "    See /tmp/ck_v7_infer_gate.log for details"
        failed=1
    fi
fi


# =============================================================================
# v7 training-kernel parity gate (default on)
# =============================================================================
if [ "${CK_V7_KERNEL_PARITY_TRAIN:-1}" = "1" ]; then
    echo -e "${YELLOW}[6/6]${NC} Running training-kernel parity gate..."
    if make --no-print-directory v7-kernel-parity-train > /tmp/ck_v7_kernel_parity_train.log 2>&1; then
        echo -e "${GREEN}  ✓ v7 training-kernel parity passed${NC}"
    else
        echo -e "${RED}  ✗ v7 training-kernel parity failed${NC}"
        echo "    See /tmp/ck_v7_kernel_parity_train.log for details"
        failed=1
    fi
else
    echo -e "${YELLOW}  ↳ v7 training-kernel parity skipped (set CK_V7_KERNEL_PARITY_TRAIN=1 to force, =0 to skip)${NC}"
fi

# =============================================================================
# Summary
# =============================================================================
echo ""
if [ $failed -eq 0 ]; then
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}  ✓ All pre-push checks passed!${NC}"
    echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
    exit 0
else
    echo -e "${RED}════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  ✗ Pre-push checks failed!${NC}"
    echo -e "${RED}════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "To push anyway: ${YELLOW}git push --no-verify${NC}"
    echo -e "Or set: ${YELLOW}export CK_SKIP_PREPUSH=1${NC}"
    echo ""
    exit 1
fi
